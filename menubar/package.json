{
  "name": "repo-radar",
  "version": "1.0.0",
  "description": "Menu bar app for Repo Radar - pristine repository mirrors with AI-powered metadata",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "package": "npm run build && node scripts/create-installer.js"
  },
  "keywords": [],
  "author": "Matt Wallington",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mattwallington/repo-radar.git"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "express": "^4.18.2",
    "sharp": "^0.34.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.mattwallington.repo-radar",
    "productName": "Repo Radar",
    "publish": null,
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "files": [
      "**/*",
      "!scripts/create-installer.js"
    ],
    "extraResources": [
      {
        "from": "resources/setup.sh",
        "to": "resources/setup.sh"
      },
      {
        "from": "../repo-radar",
        "to": "resources/repo-radar"
      },
      {
        "from": "../repo_radar",
        "to": "resources/repo_radar",
        "filter": ["!**/__pycache__/**", "!**/tests/**", "!**/*.pyc"]
      },
      {
        "from": "../requirements.txt",
        "to": "resources/requirements.txt"
      },
      {
        "from": "../VERSION",
        "to": "VERSION"
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
