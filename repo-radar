            if model.startswith('gemini/') and not os.getenv('GEMINI_API_KEY'):
                warning_msg = "⚠️ No metadata generated: GEMINI_API_KEY not configured. Configure in Settings → API Configuration."
            elif model.startswith('claude') and not os.getenv('ANTHROPIC_API_KEY'):
                warning_msg = "⚠️ No metadata generated: ANTHROPIC_API_KEY not configured. Configure in Settings → API Configuration."
            elif (model.startswith('gpt') or model.startswith('o1') or model.startswith('chatgpt/')) and not os.getenv('OPENAI_API_KEY'):
                warning_msg = "⚠️ No metadata generated: OPENAI_API_KEY not configured. Configure in Settings → API Configuration."
            elif stats['errors'] > 0:
                warning_msg = f"⚠️ No metadata generated: {stats['errors']} errors occurred (possible model not found or API issues)."
            else:
                warning_msg = f"⚠️ No metadata generated: Unknown reason. Current model: {model}"
            
            completion_data['warning'] = warning_msg
        
        send_status_update('complete', completion_data, args.status_server)
    
    return 0 if stats['errors'] == 0 else 1


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument('command', nargs='?', choices=['configure', 'sync', 'analyze', 'clean', 'help', 'get-description'])
    parser.add_argument('--dry-run', '-n', action='store_true', help='Show what would be done without executing')
    parser.add_argument('--force', '-f', action='store_true', help='Skip confirmation prompts')
    parser.add_argument('--metadata-only', action='store_true', help='Only affect metadata files (clean command)')
    parser.add_argument('--repos-only', action='store_true', help='Only affect repository directories (clean command)')
    parser.add_argument('--regenerate-metadata', action='store_true', help='Force regeneration of all metadata')
    parser.add_argument('--skip-metadata', action='store_true', help='Skip metadata generation')
    parser.add_argument('--status-server', action='store_true', help='Send status updates to HTTP server on localhost:3847')
    parser.add_argument('--version', '-V', action='store_true', help='Show version')

    args = parser.parse_args()

    if args.version:
        print(f"repo-radar v{VERSION}")
        return 0

    # Handle special commands that don't need dependencies
    if args.command == 'help' or args.command is None:
        print_help()
        return 0
    
    if args.command == 'get-description':
        get_description()
        return 0
    
    # Clean command needs inquirer but not litellm
    if args.command == 'clean':
        # Only check for inquirer (needed for confirmation)
        if not args.force and not args.dry_run:
            try:
                __import__('inquirer')
            except ImportError:
                print(f"{RED}Error: 'inquirer' package required for interactive confirmation{RESET}")
                print("Install with: pip install inquirer")
                print("Or use --force to skip confirmation")
                return 2
        return clean_mode(args)
    
    # Check dependencies for other commands
    if not check_dependencies():
        print(f"\n{RED}Cannot continue without required dependencies{RESET}")
        return 2
    
    # Route to appropriate mode
    if args.command == 'configure':
        return configure_mode(args)
    elif args.command == 'analyze':
        return analyze_mode(args)
    elif args.command == 'sync':
        return sync_mode(args)
    
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Interrupted by user{RESET}")
        sys.exit(130)
    except Exception as e:
        print(f"{RED}Unexpected error: {e}{RESET}")
        sys.exit(1)

