                    completion_percent = 90
                    status_msg = f"[{color}]⏳ waiting for AI analysis...[/{color}]"
                else:
                    completion_percent = 100
                
                progress.update(task_id, completed=completion_percent, status=status_msg)
                
                # Send status update
