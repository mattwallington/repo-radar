            expand=True
        )
        
        # Create tasks for metadata generation
        meta_tasks = {}
        for repo_config, cache_name, commit_hash, short_id, color, _ in repos_needing_metadata:
            task_id = meta_progress.add_task(
                f"[{color}]{short_id:15s}[/{color}]",
